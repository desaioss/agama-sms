    "license": "apache-2.0",
    "lastUpdated": "1706193997044",
    "tags": [
        "authentication",
        "community",
        "jans"
    ],
    "noDirectLaunch": [
        "org.gluu.agama.sms.otp"
    ],
    "configs": {
        "org.gluu.agama.sms.main": {
            "ACCOUNT_SID": "PUT_YOUR_TWILIO_ACCOUNT_SID_HERE",
            "AUTH_TOKEN": "PUT_YOUR_TWILIO_AUTH_TOKEN_HERE",
            "FROM_NUMBER": "PUT_YOUR_TWILIO_FROM_NUMBER_HERE"
        },
        "org.gluu.agama.sms.otp": {},
        "org.gluu.agama.register": {},
        "org.gluu.agama.register.flow": {},
        "org.gluu.agama.test.flow": {},
        "org.gluu.agama.register.test.flow": {},
        "org.gluu.agama.reg.test.flow": {},
        "f.af": {
            "hello": {
                "oauth": {
                    "authzEndpoint": "https://wallet.hello.coop/authorize",
                    "tokenEndpoint": "https://wallet.hello.coop/oauth/token",
                    "userInfoEndpoint": "https://wallet.hello.coop/oauth/userinfo",
                    "clientId": "CLIENT_INDENTIFIER",
                    "clientSecret": "CLIENT_SECRET",
                    "scopes": [
                        "openid"
                    ]
                },
                "uidPrefix": "hello-"
            }
        }
    },
    "name": "agama-sms"
